# jarvis-os runs 100% free and local — NO keys are required.
# Copy to .env only if you want to override defaults or enable optional adapters.

# --- Optional overrides ---------------------------------------------------
# OLLAMA_HOST=http://127.0.0.1:11434
# JARVIS_PORT=8765
# JARVIS_VAULT=./vault

# --- Optional future adapters (all OFF by default, never required) --------
# YOUTUBE_API_KEY=
# ANTHROPIC_API_KEY=
